# Copy this file to .env and fill in real values before running `docker compose up`.

# Postgres credentials used by the bundled `db` service and consumed by the backend.
POSTGRES_USER=spare
POSTGRES_PASSWORD=changeme
POSTGRES_DB=spare_notify

# Set to "false" to bypass API-key auth entirely (every request is allowed).
# Default behavior (when unset or "true") enforces X-API-Key on protected endpoints.
AUTH_ENABLED=true
